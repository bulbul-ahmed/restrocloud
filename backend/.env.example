# RestroCloud Backend — Environment Variables
# Copy this to .env.local for local development

# ─── App ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# ─── Database (PostgreSQL) ──────────────────────────────
# Option A: Docker (see docker-compose.yml)
DATABASE_URL="postgresql://restrocloud:restrocloud@localhost:5432/restrocloud_dev?schema=public"

# Option B: Herd / local PostgreSQL
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/restrocloud_dev?schema=public"

# ─── Redis ──────────────────────────────────────────────
# Option A: Docker
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Option B: Homebrew Redis (same settings, just ensure redis is running)

# ─── JWT ────────────────────────────────────────────────
# CRITICAL: Change this in production! Use: openssl rand -base64 64
JWT_SECRET=restrocloud-dev-secret-CHANGE-IN-PRODUCTION-use-openssl-rand-base64-64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
