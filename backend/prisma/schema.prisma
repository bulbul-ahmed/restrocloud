  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@map("promo_code_usages")
}

model CampaignBroadcast {
  id           String    @id @default(uuid())
  tenantId     String
  restaurantId String
  name         String
  channel      String
  segment      String
  subject      String?
  body         String
