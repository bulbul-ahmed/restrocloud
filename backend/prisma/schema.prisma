// ─── SA-D Support Tickets ─────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id          String         @id @default(uuid())
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  tenantId    String?
  submittedBy String
  assignedTo  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant?        @relation(fields: [tenantId], references: [id])
  messages    TicketMessage[]

  @@index([status])
  @@index([tenantId])
  @@map("support_tickets")
}

model TicketMessage {
  id          String        @id @default(uuid())
  ticketId    String
  authorId    String
  authorEmail String
  isStaff     Boolean       @default(false)
  content     String
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

model Announcement {
  id          String    @id @default(uuid())
  title       String
  body        String
  authorId    String
  authorEmail String
  scheduledFor DateTime? // null = publish immediately
  createdAt   DateTime  @default(now())

  @@map("announcements")
}

// ─── Knowledge Base ───────────────────────────────────────────────────────────

model KbArticle {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  body        String   @db.Text
  category    String   @default("general")
  isPublished Boolean  @default(false)
  authorId    String
  authorEmail String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("kb_articles")
}

// ─── SA-G Billing ─────────────────────────────────────────────────────────────

model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  discountPct Float     @default(0)   // percentage discount 0-100
  maxUses     Int?                    // null = unlimited
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  usages      CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  tenantId  String
  appliedBy String
  appliedAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([couponId, tenantId])
  @@map("coupon_usages")
}

// ─── SA-I Email Broadcasts ────────────────────────────────────────────────────

enum BroadcastSegment {
  ALL
  ACTIVE
  TRIAL
  PAID
  SUSPENDED
}

model Broadcast {
  id               String            @id @default(uuid())
  subject          String
  body             String
  segment          BroadcastSegment  @default(ALL)
  recipientCount   Int               @default(0)
  sentBy           String
  createdAt        DateTime          @default(now())

  @@map("broadcasts")
}

// ─── SA-L Marketing & Growth ──────────────────────────────────────────────────

model ReferralCode {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountPct   Float     @default(0)     // discount for the referred tenant
  creditPct     Float     @default(0)     // credit % added to referrer's account
  maxUses       Int?                      // null = unlimited
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  createdBy     String                    // actorEmail
  createdAt     DateTime  @default(now())
  usages        ReferralUsage[]

  @@map("referral_codes")
}

model ReferralUsage {
  id             String       @id @default(uuid())
  referralCodeId String
  referredTenantId String
  usedAt         DateTime     @default(now())
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)

  @@unique([referralCodeId, referredTenantId])
  @@map("referral_usages")
}

model InAppBanner {
  id          String    @id @default(uuid())
  title       String
  body        String
  ctaLabel    String?
  ctaUrl      String?
  targetPlan  String?   // null = all plans
  isActive    Boolean   @default(true)
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  impressions Int       @default(0)
  createdBy   String
  createdAt   DateTime  @default(now())

  @@map("in_app_banners")
}

// ─── User Login History ───────────────────────────────────────────────────────

model UserLoginHistory {
  id         String   @id @default(uuid())
  userId     String
  ipAddress  String?
  deviceInfo String?
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_login_history")
}

// ─── Plan Management ─────────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(uuid())
  name         String   @unique
  tier         PlanTier @unique
  priceMonthly Float    @default(0)
  priceAnnual  Float    @default(0)
  currency     String   @default("USD")
  maxLocations Int      @default(1)    // -1 = unlimited
  maxUsers     Int      @default(-1)   // -1 = unlimited
  features     Json     @default("{}")
  isActive     Boolean  @default(true)
  isPublic     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("plans")
}

// ─── SaaS Billing Engine ──────────────────────────────────────────────────────

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
}

enum InvoiceStatus {
  PAID
  UNPAID
  VOID
}

model TenantSubscription {
  id                 String       @id @default(uuid())
  tenantId           String       @unique
  plan               PlanTier     @default(STARTER)
  billingCycle       BillingCycle @default(MONTHLY)
  status             SubStatus    @default(TRIAL)
  currentPeriodStart DateTime     @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean      @default(false)
  stripeCustomerId   String?
  stripeSubId        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices           Invoice[]

  @@map("tenant_subscriptions")
}

model Invoice {
  id             String              @id @default(uuid())
  tenantId       String
  subscriptionId String?
  amount         Float
  currency       String              @default("USD")
  status         InvoiceStatus       @default(UNPAID)
  paidAt         DateTime?
  dueAt          DateTime
  lineItems      Json
  pdfUrl         String?
  createdAt      DateTime            @default(now())
  subscription   TenantSubscription? @relation(fields: [subscriptionId], references: [id])
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("invoices")
}

model PaymentGatewayConfig {
  id            String     @id @default(uuid())
  tenantId      String
  restaurantId  String
  gateway       String     // STRIPE | BKASH | SSLCOMMERZ
  apiKey        String?
  secretKey     String?
  webhookSecret String?
  isLive        Boolean    @default(false)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, gateway])
  @@index([tenantId])
  @@map("payment_gateway_configs")
}
