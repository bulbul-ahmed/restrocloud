generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String       @id @default(uuid())
  name             String
  slug             String       @unique
  plan             PlanTier     @default(STARTER)
  isActive         Boolean      @default(true)
  trialEndsAt      DateTime?
  creditBalance    Float        @default(0)
  flaggedForReview Boolean      @default(false)
  flagReason       String?
  terminatedAt     DateTime?
  accountManagerId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  restaurants      Restaurant[]
  users            User[]
  notes            TenantNote[]
  supportTickets   SupportTicket[]
  couponUsages     CouponUsage[]
  subscription     TenantSubscription?
  invoices         Invoice[]

  @@map("tenants")
}

model TenantNote {
  id          String   @id @default(uuid())
  tenantId    String
  content     String
  authorId    String
  authorEmail String
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_notes")
}

model Restaurant {
  id                    String                 @id @default(uuid())
  tenantId              String
  name                  String
  slug                  String
  description           String?
  logoUrl               String?
  logoWordmarkUrl       String?
  brandColor            String?  @default("#ff6b35")
  phone                 String?
  email                 String?
  website               String?
  address               String?
  city                  String?
  country               String                 @default("BD")
  timezone              String                 @default("Asia/Dhaka")
  locale                String                 @default("en")
  currency              String                 @default("BDT")
  taxRate               Decimal                @default(0) @db.Decimal(5, 2)
  taxInclusive          Boolean                @default(false)
  serviceCharge         Decimal                @default(0) @db.Decimal(5, 2)
  isActive              Boolean                @default(true)
  operatingHours        Json?
  orderTypes            OrderType[]            @default([DINE_IN, TAKEAWAY, DELIVERY])
  autoAccept            Json?
  receiptConfig         Json?
  tipOptions            Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deliveryFee           Decimal?               @db.Decimal(10, 2)
  deliveryRadiusKm      Float?
  estimatedDeliveryMin  Int?
  minimumOrderAmount    Decimal?               @db.Decimal(10, 2)
  publicSlug            String?                @unique
  autoAcceptMinutes     Json?
  qrBaseUrl             String?
  aggregatorConnections AggregatorConnection[]
  paymentGatewayConfigs PaymentGatewayConfig[]
  categories            Category[]
  combos                Combo[]
  customers             Customer[]
  deliveries            Delivery[]
  deliveryZones         DeliveryZone[]
  floorSections         FloorSection[]
  items                 Item[]
  modifierGroups        ModifierGroup[]
  orders                Order[]
  payments              Payment[]
  tables                RestaurantTable[]
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reviews               Review[]
  users                 User[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("restaurants")
}

model User {
  id                   String           @id @default(uuid())
  tenantId             String
  restaurantId         String?
  email                String?
  phone                String?
  passwordHash         String?
  pinHash              String?
  firstName            String
  lastName             String
  role                 UserRole         @default(STAFF)
  isActive             Boolean          @default(true)
  isVerified           Boolean          @default(false)
  twoFaSecret          String?
  twoFaEnabled         Boolean          @default(false)
  lastLoginAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  twoFaPending         Boolean          @default(false)
  emailVerifyToken     String?          @unique
  emailVerifyExpires   DateTime?
  passwordResetToken   String?          @unique
  passwordResetExpires DateTime?
  bankAccount          String?
  emergencyContact     String?
  emergencyPhone       String?
  employmentType       String?
  hireDate             DateTime?
  hourlyRate           Decimal?         @db.Decimal(10, 2)
  hrNotes              String?
  monthlySalary        Decimal?         @db.Decimal(10, 2)
  deliveries           Delivery[]       @relation("DriverDeliveries")
  leaveRequests        LeaveRequest[]   @relation("EmployeeLeaveRequests")
  orders               Order[]          @relation("CreatedByUser")
  rolePerms            RolePermission[]
  shifts               Shift[]          @relation("EmployeeShifts")
  timeEntries          TimeEntry[]      @relation("EmployeeTimeEntries")
  tipRecords           TipRecord[]      @relation("EmployeeTipRecords")
  sessions             UserSession[]
  loginHistory         UserLoginHistory[]
  restaurant           Restaurant?      @relation(fields: [restaurantId], references: [id])
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([restaurantId])
  @@map("users")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model Permission {
  id              String           @id @default(uuid())
  resource        String
  action          String
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("role_permissions")
}

model Category {
  id           String     @id @default(uuid())
  tenantId     String
  restaurantId String
  name         String
  description  String?
  imageUrl     String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        Item[]

  @@index([tenantId])
  @@index([restaurantId])
  @@map("categories")
}

model Item {
  id              String              @id @default(uuid())
  tenantId        String
  restaurantId    String
  categoryId      String
  name            String
  description     String?
  imageUrl        String?
  price           Decimal             @db.Decimal(10, 2)
  costPrice       Decimal?            @db.Decimal(10, 2)
  sku             String?
  barcode         String?
  isAvailable     Boolean             @default(true)
  isAlcohol       Boolean             @default(false)
  calories        Int?
  allergens       String[]            @default([])
  dietaryTags     String[]            @default([])
  sortOrder       Int                 @default(0)
  preparationTime Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  comboItems      ComboItem[]
  modifierGroups  ItemModifierGroup[]
  category        Category            @relation(fields: [categoryId], references: [id])
  restaurant      Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@index([tenantId])
  @@index([restaurantId])
  @@index([categoryId])
  @@map("items")
}

model ModifierGroup {
  id               String              @id @default(uuid())
  tenantId         String
  restaurantId     String
  name             String
  minSelect        Int                 @default(0)
  maxSelect        Int                 @default(1)
  isRequired       Boolean             @default(false)
  parentModifierId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  itemGroups       ItemModifierGroup[]
  restaurant       Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  modifiers        Modifier[]
  parentModifier   Modifier?           @relation("ChildGroups", fields: [parentModifierId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([restaurantId])
  @@index([parentModifierId])
  @@map("modifier_groups")
}

model Modifier {
  id              String          @id @default(uuid())
  tenantId        String
  modifierGroupId String
  name            String
  priceAdjustment Decimal         @default(0) @db.Decimal(10, 2)
  isDefault       Boolean         @default(false)
  isAvailable     Boolean         @default(true)
  isRequired      Boolean         @default(false)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  modifierGroup   ModifierGroup   @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderModifiers  OrderModifier[]
  childGroups     ModifierGroup[] @relation("ChildGroups")

  @@index([tenantId])
  @@index([modifierGroupId])
  @@map("modifiers")
}

model ItemModifierGroup {
  itemId          String
  modifierGroupId String
  sortOrder       Int           @default(0)
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([itemId, modifierGroupId])
  @@map("item_modifier_groups")
}

model Combo {
  id           String      @id @default(uuid())
  tenantId     String
  restaurantId String
  name         String
  description  String?
  imageUrl     String?
  price        Decimal     @db.Decimal(10, 2)
  isAvailable  Boolean     @default(true)
  validFrom    DateTime?
  validUntil   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        ComboItem[]
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([restaurantId])
  @@map("combos")
}

model ComboItem {
  id       String @id @default(uuid())
  comboId  String
  itemId   String
  quantity Int    @default(1)
  combo    Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)
  item     Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("combo_items")
}

model Order {
  id               String               @id @default(uuid())
  tenantId         String
  restaurantId     String
  orderNumber      String
  channel          OrderType            @default(DINE_IN)
  status           OrderStatus          @default(PENDING)
  tableId          String?
  tableSessionId   String?
  customerId       String?
  createdById      String?
  notes            String?
  subtotal         Decimal              @db.Decimal(10, 2)
  taxAmount        Decimal              @default(0) @db.Decimal(10, 2)
  serviceCharge    Decimal              @default(0) @db.Decimal(10, 2)
  tipAmount        Decimal              @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal              @default(0) @db.Decimal(10, 2)
  totalAmount      Decimal              @db.Decimal(10, 2)
  currency         String               @default("BDT")
  estimatedReadyAt DateTime?
  acceptedAt       DateTime?
  readyAt          DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  externalOrderId  String?
  aggregatorName   String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  guestName        String?
  guestPhone       String?
  cartToken        String?
  deviceId         String?
  deviceIp         String?
  deviceUserAgent  String?
  deliveryAddress  Json?
  delivery         Delivery?
  items            OrderItem[]
  statusHistory    OrderStatusHistory[]
  createdBy        User?                @relation("CreatedByUser", fields: [createdById], references: [id])
  customer         Customer?            @relation(fields: [customerId], references: [id])
  restaurant       Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table            RestaurantTable?     @relation(fields: [tableId], references: [id])
  tableSession     TableSession?        @relation(fields: [tableSessionId], references: [id])
  payments         Payment[]

  @@unique([restaurantId, orderNumber])
  @@index([tenantId])
  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  changedAt DateTime    @default(now())
  changedBy String?
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model OrderItem {
  id            String          @id @default(uuid())
  tenantId      String
  orderId       String
  itemId        String?
  name          String
  quantity      Int             @default(1)
  unitPrice     Decimal         @db.Decimal(10, 2)
  totalPrice    Decimal         @db.Decimal(10, 2)
  notes         String?
  isVoid        Boolean         @default(false)
  kitchenStatus KitchenStatus   @default(QUEUED)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  item          Item?           @relation(fields: [itemId], references: [id], onDelete: Restrict)
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  modifiers     OrderModifier[]

  @@index([tenantId])
  @@index([orderId])
  @@map("order_items")
}

model OrderModifier {
  id          String    @id @default(uuid())
  orderItemId String
  modifierId  String
  name        String
  priceAdjust Decimal   @db.Decimal(10, 2)
  modifier    Modifier  @relation(fields: [modifierId], references: [id])
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("order_modifiers")
}

model Payment {
  id              String                @id @default(uuid())
  tenantId        String
  restaurantId    String
  orderId         String
  amount          Decimal               @db.Decimal(10, 2)
  currency        String                @default("BDT")
  method          PaymentMethod
  status          PaymentStatus         @default(PENDING)
  gatewayName     String?
  gatewayTxId     String?
  gatewayResponse Json?
  paidAt          DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  onlineSession   OnlinePaymentSession?
  order           Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  restaurant      Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  refunds         Refund[]
  transactions    Transaction[]

  @@index([tenantId])
  @@index([orderId])
  @@map("payments")
}

model Refund {
  id           String       @id @default(uuid())
  tenantId     String
  paymentId    String
  amount       Decimal      @db.Decimal(10, 2)
  reason       String?
  status       RefundStatus @default(PENDING)
  gatewayRefId String?
  processedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([paymentId])
  @@map("refunds")
}

model Transaction {
  id          String          @id @default(uuid())
  tenantId    String
  paymentId   String
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("BDT")
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  payment     Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([paymentId])
  @@map("transactions")
}

model FloorSection {
  id           String            @id @default(uuid())
  tenantId     String
  restaurantId String
  name         String
  description  String?
  sortOrder    Int               @default(0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables       RestaurantTable[]

  @@index([tenantId])
  @@index([restaurantId])
  @@map("floor_sections")
}

model RestaurantTable {
  id             String         @id @default(uuid())
  tenantId       String
  restaurantId   String
  floorSectionId String
  tableNumber    String
  capacity       Int            @default(2)
  status         TableStatus    @default(AVAILABLE)
  qrCode         String?        @unique
  posX           Float?
  posY           Float?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  orders         Order[]
  floorSection   FloorSection   @relation(fields: [floorSectionId], references: [id])
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sessions       TableSession[]

  @@unique([restaurantId, floorSectionId, tableNumber])
  @@index([tenantId])
  @@index([restaurantId])
  @@map("restaurant_tables")
}

model TableSession {
  id         String          @id @default(uuid())
  tenantId   String
  tableId    String
  guestCount Int             @default(1)
  status     SessionStatus   @default(OPEN)
  openedAt   DateTime        @default(now())
  closedAt   DateTime?
  closedBy   String?
  notes      String?
  orders     Order[]
  table      RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tableId])
  @@map("table_sessions")
}

model Customer {
  id                    String                 @id @default(uuid())
  tenantId              String
  restaurantId          String
  firstName             String
  lastName              String?
  email                 String?
  phone                 String?
  notes                 String?
  isBlacklisted         Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  isVerified            Boolean                @default(false)
  lastLoginAt           DateTime?
  passwordHash          String?
  dateOfBirth           DateTime?
  addresses             Address[]
  customerNotifications CustomerNotification[]
  restaurant            Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  loyaltyAccount        LoyaltyAccount?
  orders                Order[]
  promoCodeUsages       PromoCodeUsage[]
  reviews               Review[]
  savedPaymentMethods   SavedPaymentMethod[]
  stampProgresses       StampProgress[]

  @@unique([restaurantId, phone])
  @@unique([restaurantId, email])
  @@index([tenantId])
  @@index([restaurantId])
  @@map("customers")
}

model Address {
  id         String   @id @default(uuid())
  tenantId   String
  customerId String
  label      String?
  line1      String
  line2      String?
  city       String
  area       String?
  postalCode String?
  country    String   @default("BD")
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@map("addresses")
}

model LoyaltyAccount {
  id            String               @id @default(uuid())
  tenantId      String
  customerId    String               @unique
  points        Int                  @default(0)
  totalEarned   Int                  @default(0)
  totalRedeemed Int                  @default(0)
  tier          String               @default("BRONZE")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions  LoyaltyTransaction[]

  @@index([tenantId])
  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id               String         @id @default(uuid())
  tenantId         String
  loyaltyAccountId String
  type             String
  points           Int
  description      String?
  orderId          String?
  createdAt        DateTime       @default(now())
  loyaltyAccount   LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([loyaltyAccountId])
  @@map("loyalty_transactions")
}

model Notification {
  id           String           @id @default(uuid())
  tenantId     String
  restaurantId String
  userId       String
  type         NotificationType
  title        String
  body         String
  data         Json?
  isRead       Boolean          @default(false)
  readAt       DateTime?
  createdAt    DateTime         @default(now())

  @@index([tenantId, userId])
  @@index([userId, isRead])
  @@index([restaurantId])
  @@map("notifications")
}

model NotificationPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  tenantId        String
  restaurantId    String
  pushEnabled     Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  mutedTypes      Json     @default("[]")
  quietHoursStart String?
  quietHoursEnd   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@map("notification_preferences")
}

model Review {
  id           String     @id @default(uuid())
  tenantId     String
  restaurantId String
  customerId   String?
  orderId      String?
  rating       Int
  comment      String?
  channel      String?
  isApproved   Boolean    @default(false)
  isHidden     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  customer     Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([restaurantId])
  @@index([customerId])
  @@map("reviews")
}

model SavedPaymentMethod {
  id           String   @id @default(uuid())
  tenantId     String
  customerId   String
  restaurantId String
  gateway      String
  label        String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@map("saved_payment_methods")
}

model CustomerNotification {
  id           String    @id @default(uuid())
  tenantId     String
  customerId   String
  restaurantId String
  type         String
  title        String
  body         String
  data         Json?
  isRead       Boolean   @default(false)
  readAt       DateTime?
  createdAt    DateTime  @default(now())
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([customerId, isRead])
  @@map("customer_notifications")
}

model OnlinePaymentSession {
  id               String   @id @default(uuid())
  tenantId         String
  restaurantId     String
  orderId          String
  paymentId        String   @unique
  gateway          String
  sessionData      Json
  expiresAt        DateTime
  webhookProcessed Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  payment          Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("online_payment_sessions")
}

model DeliveryZone {
  id           String     @id @default(uuid())
  tenantId     String
  restaurantId String
  name         String
  radiusKm     Float
  extraFee     Decimal    @default(0) @db.Decimal(10, 2)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deliveries   Delivery[]
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([restaurantId])
  @@map("delivery_zones")
}

model Delivery {
  id           String         @id @default(uuid())
  tenantId     String
  restaurantId String
  orderId      String         @unique
  driverId     String?
  zoneId       String?
  status       DeliveryStatus @default(PENDING)
  proofUrl     String?
  proofNotes   String?
  estimatedAt  DateTime?
  assignedAt   DateTime?
  pickedUpAt   DateTime?
  inTransitAt  DateTime?
  deliveredAt  DateTime?
  failedAt     DateTime?
  cancelledAt  DateTime?
  failReason   String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  driver       User?          @relation("DriverDeliveries", fields: [driverId], references: [id])
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  zone         DeliveryZone?  @relation(fields: [zoneId], references: [id])

  @@index([tenantId])
  @@index([restaurantId])
  @@index([driverId])
  @@index([status])
  @@map("deliveries")
}

model AggregatorConnection {
  id              String     @id @default(uuid())
  tenantId        String
  restaurantId    String
  platform        String
  displayName     String?
  isActive        Boolean    @default(true)
  isConnected     Boolean    @default(false)
  apiKey          String?
  apiSecret       String?
  webhookSecret   String?
  commissionType  String     @default("PERCENTAGE")
  commissionValue Decimal    @default(0) @db.Decimal(10, 4)
  autoAccept      Boolean    @default(false)
  lastSyncedAt    DateTime?
  lastOrderAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, platform])
  @@index([tenantId])
  @@index([restaurantId])
  @@map("aggregator_connections")
}

model Ingredient {
