  @@index([restaurantId])
  @@map("ingredients")
}

model RecipeItem {
  id           String     @id @default(uuid())
  tenantId     String
  itemId       String
  ingredientId String
  quantity     Float
  unit         UnitType
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([itemId, ingredientId])
  @@index([tenantId])
  @@index([itemId])
  @@map("recipe_items")
}

model StockMovement {
  id           String       @id @default(uuid())
  tenantId     String
  restaurantId String
  ingredientId String
  type         MovementType
  quantity     Float
  reason       String?
  notes        String?
  orderId      String?
  createdById  String?
