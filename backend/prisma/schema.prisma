  updatedAt    DateTime  @updatedAt
  user         User      @relation("EmployeeTimeEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([restaurantId])
  @@index([userId])
  @@index([clockIn])
  @@map("time_entries")
}

model TipRecord {
  id           String   @id @default(uuid())
  tenantId     String
  restaurantId String
  userId       String
  amount       Decimal  @db.Decimal(10, 2)
  source       String
  orderId      String?
  date         DateTime @default(now())
